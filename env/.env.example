# Plane environment configuration template
# Copy this file to .env.local and edit values
# NEVER commit .env.local to git

# ============================================================
# DATABASE (PostgreSQL)
# ============================================================
POSTGRES_USER=plane
POSTGRES_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD
POSTGRES_DB=plane
POSTGRES_HOST=plane-postgres
POSTGRES_PORT=5432
# Recommend: python3 -c "import secrets; print(secrets.token_urlsafe(32))"

# ============================================================
# APPLICATION
# ============================================================
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_64_CHARS_RANDOM_STRING

# Domain/IP where Plane is accessible
WEB_URL=http://192.168.1.100
CORS_ALLOWED_ORIGINS=http://192.168.1.100

# ============================================================
# STORAGE (MinIO - S3 Compatible)
# ============================================================
MINIO_ROOT_USER=plane-minio
MINIO_ROOT_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD
AWS_S3_ENDPOINT_URL=http://plane-minio:9000
AWS_S3_BUCKET_NAME=plane-uploads
AWS_ACCESS_KEY_ID=plane-minio
AWS_SECRET_ACCESS_KEY=CHANGE_ME_USE_STRONG_PASSWORD

# ============================================================
# REDIS
# ============================================================
REDIS_URL=redis://plane-redis:6379/

# ============================================================
# RABBITMQ (Celery Broker)
# ============================================================
RABBITMQ_DEFAULT_USER=plane
RABBITMQ_DEFAULT_PASS=CHANGE_ME_USE_STRONG_PASSWORD
CELERY_BROKER_URL=amqp://plane:CHANGE_ME@plane-rabbitmq:5672/

# ============================================================
# EMAIL (SMTP) - Optional
# ============================================================
# Uncomment and configure if you have an internal mail server
# EMAIL_HOST=smtp.internal.local
# EMAIL_PORT=587
# EMAIL_HOST_USER=plane@internal.local
# EMAIL_HOST_PASSWORD=xxx
# EMAIL_USE_TLS=1
# DEFAULT_FROM_EMAIL=plane@internal.local

# ============================================================
# OPTIONAL: AI Features (disable for air-gapped)
# ============================================================
# OPENAI_API_KEY=
# GPT_ENGINE=

# ============================================================
# SECURITY
# ============================================================
# Disable telemetry for air-gapped/security environments
TELEMETRY_DISABLED=true
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax
